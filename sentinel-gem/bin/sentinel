#!/usr/bin/env ruby
require "rbconfig"

# Detect architecture
host_os = RbConfig::CONFIG['host_os']
arch = case host_os
       when /mswin|msys|mingw|cygwin|bccwin|wince|emc/
         "windows"
       when /darwin|mac os/
         "darwin"
       else
         "linux"
       end

binary_path = File.expand_path("../exe/sentinel-x86_64-#{arch}", __dir__)

if File.exist?(binary_path)
  # Forward all arguments from the ruby command to the Rust binary
  exec(binary_path, *ARGV)
else
  abort "Sentinel binary not found for your platform (#{host_os})."
end
